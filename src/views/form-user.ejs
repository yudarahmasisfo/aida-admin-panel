<!DOCTYPE html>
<html lang="id">
<%- include('partials/head') %>
<body class="bg-slate-50 flex flex-col lg:flex-row">
    <%- include('partials/sidebar') %>
    
    <main class="flex-1 ml-0 lg:ml-64 p-4 lg:p-10 pt-24 lg:pt-10">
        <div class="mb-8">
            <a href="/users" class="text-blue-600 hover:text-blue-700 font-medium flex items-center gap-2 mb-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Kembali ke Daftar User
            </a>
            <h1 class="text-2xl font-bold text-slate-800"><%= item ? 'Edit' : 'Tambah' %> Pengguna Baru</h1>
            <p class="text-slate-500 text-sm">Kelola akses warga dan staf administrasi desa.</p>
        </div>

        <div class="max-w-2xl bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="p-8">
                <% if (error) { %>
                    <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 text-sm rounded-r-lg">
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>
                            <%= error %>
                        </div>
                    </div>
                <% } %>

                <form action="/users/save" method="POST" class="space-y-6">
                    <input type="hidden" name="id" value="<%= item ? item.id : '' %>">

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Nama Lengkap</label>
                        <input type="text" name="nama" value="<%= item ? item.nama : '' %>" required
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"
                            placeholder="Contoh: Budi Santoso">
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Username</label>
                        <input type="text" name="username" value="<%= item ? item.username : '' %>" required
                            <%= item ? 'readonly class="bg-slate-50 opacity-70 cursor-not-allowed"' : '' %>
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"
                            placeholder="budi_desa">
                        <% if(item) { %><small class="text-slate-400 mt-1 block">Username tidak dapat diubah.</small><% } %>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">
                            <%= item ? 'Ganti Password' : 'Password' %>
                        </label>
                        <input type="password" name="password" <%= item ? '' : 'required' %>
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"
                            placeholder="••••••••">
                        <% if(item) { %><small class="text-slate-400 mt-1 block">Biarkan kosong jika tidak ingin mengubah password.</small><% } %>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Role Akses</label>
                        <select name="role" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition appearance-none bg-white">
                            <option value="member" <%= (item && item.role === 'member') ? 'selected' : '' %>>Member (Warga Desa)</option>
                            <option value="admin" <%= (item && item.role === 'admin') ? 'selected' : '' %>>Admin (Perangkat Desa)</option>
                            <option value="guest" <%= (item && item.role === 'guest') ? 'selected' : '' %>>Guest (Pengunjung)</option>
                        </select>
                    </div>

                    <div class="pt-4 border-t border-slate-100 flex gap-3">
                        <button type="submit" class="flex-1 bg-blue-600 text-white py-3.5 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-200">
                            <%= item ? 'Update Data User' : 'Daftarkan User' %>
                        </button>
                        <a href="/users" class="px-6 py-3.5 bg-slate-100 text-slate-600 rounded-xl font-bold hover:bg-slate-200 transition">
                            Batal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
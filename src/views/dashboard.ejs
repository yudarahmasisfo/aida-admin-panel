<!DOCTYPE html>
<html lang="id">
<%- include('partials/head') %>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.tailwind.min.css">
<style>
    /* Styling agar DataTable menyatu dengan desain Tailwind Bapak */
    .dataTables_wrapper .dataTables_filter input {
        border-radius: 12px; border: 1px solid #e2e8f0; padding: 6px 12px; outline: none; margin-bottom: 10px;
    }
    
    /* Perbaikan Paging agar tidak berhimpit */
    .dataTables_wrapper .dataTables_paginate {
        margin-top: 20px;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 8px !important; 
        border: 1px solid #e2e8f0 !important;
        background: white !important;
        padding: 5px 12px !important;
        margin: 0 2px !important;
        cursor: pointer !important;
        color: #64748b !important;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background: #3b82f6 !important;
        color: white !important;
        border-color: #3b82f6 !important;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button:hover:not(.current) {
        background: #f8fafc !important;
        border-color: #cbd5e1 !important;
    }
    .dataTables_wrapper .dataTables_info {
        padding-top: 20px;
        color: #64748b;
        font-size: 0.875rem;
    }

    table.dataTable thead th { border-bottom: 1px solid #f1f5f9 !important; }
    
    @media print {
        .lg\:ml-64 { margin-left: 0 !important; }
        aside, button, .dataTables_filter, .dataTables_length, .dataTables_paginate { display: none !important; }
    }

    /* Styling untuk Dropdown LengthMenu */
.dataTables_length select {
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    padding: 4px 30px 4px 10px; /* Beri space untuk panah dropdown */
    outline: none;
    background-color: white;
    cursor: pointer;
    margin: 0 5px;
}

/* Pastikan label "Tampilkan" dan "data" sejajar */
.dataTables_length label {
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    color: #64748b;
}

/* Merapikan posisi Search Bar agar tidak menempel ke dropdown */
.dataTables_filter label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: #64748b;
}
</style>
<body class="bg-slate-50 flex flex-col lg:flex-row">
    <%- include('partials/sidebar') %>

    <main class="flex-1 ml-0 lg:ml-64 p-4 lg:p-10 pt-24 lg:pt-10">
        <div class="max-w-6xl mx-auto">

            <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl lg:text-3xl font-bold text-slate-800">Dashboard Monitoring</h1>
                    <p class="text-slate-500 mt-1">Pantau interaksi warga dengan AI Asisten Desa (AIDA)</p>
                </div>
                <button onclick="window.print()" class="bg-white border border-slate-200 text-slate-700 px-5 py-2.5 rounded-xl font-semibold hover:bg-slate-50 transition shadow-sm flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                    Cetak Laporan
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex items-center gap-4">
                        <div class="p-3 bg-blue-50 rounded-xl text-blue-600">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-slate-500">Total Chat Hari Ini</p>
                            <h3 class="text-3xl font-bold text-slate-800 mt-1">
                                <%= stats.chatHariIni %> </h3>
                            </h3>
                        </div>
                    </div>
                </div>

<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
    <div class="flex items-center gap-4">
        <div class="p-3 bg-amber-50 rounded-xl text-amber-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
        </div>
        <div>
            <p class="text-sm font-medium text-slate-500">Total Akumulasi Chat</p>
            <h3 class="text-2xl font-bold text-slate-800 mt-1">
                <%= stats.totalChat %> 
                <span class="text-xs font-normal text-slate-400 ml-1">Pesan</span>
            </h3>
        </div>
    </div>
</div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <p class="text-sm font-medium text-slate-500 mb-2">Status Server AI</p>
                    <% if (aiStatus.online) { %>
                        <h3 class="text-xl font-bold text-green-500 flex items-center gap-2">
                            <span class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></span>
                            <%= aiStatus.message %>
                        </h3>
                    <% } else { %>
                        <h3 class="text-xl font-bold text-red-500 flex items-center gap-2">
                            <span class="w-3 h-3 bg-red-500 rounded-full"></span>
                            <%= aiStatus.message %>
                        </h3>
                    <% } %>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="p-6 border-b border-slate-100 flex justify-between items-center">
                    <h2 class="font-bold text-slate-700">Riwayat Percakapan Terbaru</h2>
                    <span class="text-xs font-medium bg-blue-50 text-blue-600 px-3 py-1 rounded-full">Real-time</span>
                </div>

                <div class="p-6">
                    <div class="overflow-x-auto">
                        <table id="logTable" class="w-full text-left display">
                            <thead class="bg-slate-50 text-slate-600 uppercase text-xs font-bold tracking-wider">
                                <tr>
                                    <th class="p-4">Waktu</th>
                                    <th class="p-4">Pertanyaan Warga</th>
                                    <th class="p-4">Jawaban AI (AIDA)</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% if (logs && logs.length > 0) { %>
                                    <% logs.forEach(log => { %>
                                    <tr class="hover:bg-slate-50 transition">
                                        <td class="p-4 text-xs text-slate-400 whitespace-nowrap">
                                            <%= new Date(log.createdAt).toLocaleString('id-ID', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: 'short' }) %>
                                        </td>
                                        <td class="p-4 text-sm font-semibold text-slate-700 max-w-xs truncate">
                                            <%= log.pertanyaan %>
                                        </td>
                                        <td class="p-4 text-sm text-slate-600">
                                            <div class="max-h-24 overflow-y-auto bg-blue-50/30 p-3 rounded-lg border border-blue-100/50 text-xs italic">
                                                <%= log.jawaban %>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.tailwind.min.js"></script>

<script>
    $(document).ready(function() {
        $('#logTable').DataTable({
            // Konfigurasi Bahasa Manual agar lebih rapi
            "language": {
                "sProcessing":   "Sedang memproses...",
                "sLengthMenu":   "Tampilkan _MENU_ entri",
                "sZeroRecords":  "Tidak ditemukan data yang sesuai",
                "sInfo":         "Menampilkan _START_ sampai _END_ dari _TOTAL_ entri",
                "sInfoEmpty":    "Menampilkan 0 sampai 0 dari 0 entri",
                "sInfoFiltered": "(disaring dari _MAX_ entri keseluruhan)",
                "sInfoPostFix":  "",
                "sSearch":       "Cari:",
                "sUrl":          "",
                "oPaginate": {
                    "sFirst":    "«",
                    "sPrevious": "‹ Prev",
                    "sNext":     "Next ›",
                    "sLast":     "»"
                }
            },
            "pageLength": 5,
            "lengthMenu": [5, 10, 25, 50], // Admin bisa pilih jumlah baris
            "order": [[0, "desc"]],
            "responsive": true,
            "dom": '<"flex flex-col md:flex-row justify-between items-center gap-4 mb-4"lf>rt<"flex flex-col md:flex-row justify-between items-center mt-4"ip>'
        });
    });
</script>
</body>
</html>